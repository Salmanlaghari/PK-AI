<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_root"
    android:layout_width="0dp"
    android:layout_height="115dp"
    android:layout_columnWeight="1"
    android:layout_margin="6dp"
    android:background="@drawable/bg_glass_card"
    android:padding="14dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Subtle Diagonal Shine Streak Overlay -->
    <View
        android:id="@+id/view_shine"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_diagonal_shine"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Tool Emoji Icon -->
    <TextView
        android:id="@+id/tv_tool_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧠"
        android:textSize="26sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Tool Name -->
    <TextView
        android:id="@+id/tv_tool_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Claude"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_tool_icon" />

    <!-- Tool Status Badge -->
    <TextView
        android:id="@+id/tv_tool_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:paddingHorizontal="9dp"
        android:paddingVertical="3dp"
        android:text="ACTIVE"
        android:textColor="#04262a"
        android:textSize="9sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins"
        android:letterSpacing="0.05"
        android:background="@drawable/bg_status_active_badge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_tool_name" />

</androidx.constraintlayout.widget.ConstraintLayout>
