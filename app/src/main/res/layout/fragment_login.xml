<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/premium_black"
    android:padding="24dp">

    <!-- Top Glow Effect (Electric Blue & Purple Gradient Orb) -->
    <View
        android:id="@+id/view_glow_orb"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="-150dp"
        android:background="@drawable/bg_gradient_button"
        android:alpha="0.25"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Centered Glassmorphism Card Wrapper -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_login_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- App Icon Symbol -->
        <ImageView
            android:id="@+id/iv_app_logo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="8dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_launcher_foreground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_login_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/title_login"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_app_logo" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tv_login_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/subtitle_login"
            android:textColor="@color/electric_blue_glow"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_login_title" />

        <!-- Loading State Container (Hidden by default) -->
        <LinearLayout
            android:id="@+id/layout_loading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_login_subtitle">

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/electric_blue_glow" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/lbl_loading"
                android:textColor="@color/white"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Credentials / Button Options Group -->
        <LinearLayout
            android:id="@+id/layout_auth_options"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_login_subtitle">

            <!-- Sign in with Google Button (Electric Blue Glow & Purple Gradient accent) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_google_signin"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/purple_accent"
                android:text="@string/btn_sign_in_google"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_google"
                app:iconSize="20dp"
                app:iconTint="@color/white"
                app:cornerRadius="24dp" />

            <!-- Continue as Guest Button (Electric Blue outlined feel) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_guest_signin"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/btn_guest_mode"
                android:textColor="@color/electric_blue_glow"
                android:textSize="15sp"
                app:strokeColor="@color/electric_blue_glow"
                app:strokeWidth="1.5dp"
                app:cornerRadius="24dp" />
        </LinearLayout>

        <!-- Dynamic Error Banner State -->
        <TextView
            android:id="@+id/tv_error_banner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card"
            android:backgroundTint="#22EF4444"
            android:gravity="center"
            android:padding="12dp"
            android:text="@string/error_auth_failed"
            android:textColor="@color/error"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_auth_options" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
