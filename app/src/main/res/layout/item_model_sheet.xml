<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/btn_model_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_model_item_default"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="20dp"
    android:paddingVertical="14dp">

    <TextView
        android:id="@+id/tv_model_emoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💎"
        android:textSize="18sp"
        android:layout_marginEnd="16dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_model_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/poppins"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_model_provider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/outline"
            android:textSize="12sp"
            android:fontFamily="@font/poppins" />
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_model_check"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="Selected"
        android:src="@drawable/ic_check"
        android:visibility="gone"
        app:tint="@color/electric_blue_glow" />

</LinearLayout>
