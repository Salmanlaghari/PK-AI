<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base dark background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0d1224"
                android:endColor="#05060a"
                android:angle="270" />
        </shape>
    </item>

    <!-- Top Glow Overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#208b5cf6"
                android:centerColor="#05060a"
                android:endColor="#000000"
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.2"
                android:centerY="0.1" />
        </shape>
    </item>

    <!-- Bottom Glow Overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1A3ff0ff"
                android:endColor="#000000"
                android:type="radial"
                android:gradientRadius="450dp"
                android:centerX="0.8"
                android:centerY="0.9" />
        </shape>
    </item>
</layer-list>
